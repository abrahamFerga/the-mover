<Window x:Class="TheMover.Overlay.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="The Mover — Break time"
        WindowStyle="None"
        ResizeMode="NoResize"
        Topmost="True"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterScreen"
        Width="420" Height="280"
        Background="#FF1E1E2E">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="40" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock x:Name="TierLabel"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="#FFB4BEFE"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,6" />
            <TextBlock Text="Step away from the screen"
                       FontSize="22" FontWeight="Bold"
                       Foreground="#FFCDD6F4"
                       HorizontalAlignment="Center" />
        </StackPanel>

        <TextBlock x:Name="CountdownLabel"
                   Grid.Row="1"
                   FontSize="48" FontWeight="Bold"
                   Foreground="#FFA6E3A1"
                   HorizontalAlignment="Center"
                   Margin="0,8,0,8" />

        <ProgressBar x:Name="CountdownBar"
                     Grid.Row="2"
                     Height="6"
                     Margin="40,0,40,16"
                     Foreground="#FFA6E3A1"
                     Background="#FF313244"
                     Maximum="1" Value="1" />

        <StackPanel Grid.Row="3" Orientation="Horizontal"
                    HorizontalAlignment="Center" Margin="0,0,0,16">
            <Button x:Name="SnoozeButton"
                    Content="Snooze"
                    Width="110" Height="36"
                    Margin="0,0,12,0"
                    FontSize="14"
                    Click="Snooze_Click"
                    Background="#FF45475A"
                    Foreground="#FFCDD6F4"
                    BorderThickness="0" />
            <Button x:Name="SkipButton"
                    Content="Skip"
                    Width="110" Height="36"
                    FontSize="14"
                    Click="Skip_Click"
                    Background="#FF45475A"
                    Foreground="#FFCDD6F4"
                    BorderThickness="0" />
        </StackPanel>
    </Grid>
</Window>
